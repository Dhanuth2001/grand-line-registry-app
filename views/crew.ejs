<!DOCTYPE html>
<html lang="en" data-theme="cupcake"> <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Crew Roster</title>
    <link rel="stylesheet" href="/css/main.css">
</head>
<body class="bg-base-100 min-h-screen">
    <%- include('partials/navbar', { title: 'Crew Roster' }) %>

    <main class="container mx-auto p-4">
        <h1 class="text-3xl font-bold mb-6">The Grand Line Roster</h1>
        <div class="overflow-x-auto">
            <table class="table table-zebra w-full shadow-lg">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Name</th>
                        <th>Role</th>
                        <th>Devil Fruit</th>
                        <th>Bounty</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                    <% let i = 1; %>
                    <% for (const member of crew) { %>
                    <tr>
                        <th><%= i++ %></th>
                        <td class="font-bold"><%= member.name %></td>
                        <td><%= member.role %></td>
                        <td><%= member.devilFruit %></td>
                        <td><%= member.bounty.toLocaleString() %> Berries</td>
                        <td>
                            <% if (member.status === 'active') { %>
                                <span class="badge badge-success">Active</span>
                            <% } else if (member.status === 'pending') { %>
                                <span class="badge badge-warning">Pending Approval</span>
                            <% } else { %>
                                <span class="badge badge-error">Bounty Frozen</span>
                            <% } %>
                        </td>
                    </tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </main>
</body>
</html>